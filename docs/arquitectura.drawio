                <mxCell id="6" value="&lt;div style=&quot;&quot;&gt;&lt;div&gt;Estilos Arquitectónicos&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;· En Capas (NestJS: Controller→Service→Repository)&lt;/div&gt;&lt;div&gt;· Cliente-Servidor (SPA→API Gateway→Master)&lt;/div&gt;&lt;div&gt;· Event-Driven / EDA (Broker RabbitMQ AMQPS,&lt;/div&gt;&lt;div&gt;&amp;nbsp; ACK/NACK, mensajes package-transit,&lt;/div&gt;&lt;div&gt;&amp;nbsp; distance-table, audit)&lt;/div&gt;&lt;div&gt;· Adapter (connector: broker payload → CreatePackageDto)&lt;/div&gt;&lt;div&gt;· API Gateway (AWS HTTP API: auth, CORS, routing,&lt;/div&gt;&lt;div&gt;&amp;nbsp; shared secret hacia origen)&lt;/div&gt;&lt;/div&gt;" style="shape=note;strokeWidth=2;fontSize=11;size=20;whiteSpace=wrap;html=1;fillColor=#E8F4FD;strokeColor=#d6b656;fontColor=#666600;align=center;" vertex="1" parent="1">
