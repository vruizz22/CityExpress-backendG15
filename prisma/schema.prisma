generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

model PackageEvent {
  idpk             String    @id
  type             String
  packageId        String
  deliveryStrategy String
  maxHops          Int
  createdAt        DateTime
  deliverNotBefore DateTime?
  originId         String
  destinationId    String
  metaContent      String?
  isMetaEncrypted  Boolean
  constraints      Json?
  priorityClass    String
  payment          Float
  senderCityId     String?
  receivedAt       DateTime  @default(now())

  @@index([packageId, receivedAt])
  @@index([destinationId])
}

model Route {
  code          String   @id
  name          String
  enabled       Boolean  @default(false)
  distance      BigInt?
  transportCost BigInt?
  updatedAt     DateTime @updatedAt
}

model AuditEvent {
  idpk      String   @id
  packageId String
  type      String
  data      Json?
  createdAt DateTime @default(now())

  @@index([packageId, createdAt])
  @@index([type])
}

model User {
  id        String   @id @default(uuid())
  subject   String   @unique
  email     String?
  createdAt DateTime @default(now())
}
