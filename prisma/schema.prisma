generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

model PackageEvent {
  idpk             String    @id
  type             String
  packageId        String
  deliveryStrategy String
  maxHops          Int
  createdAt        DateTime
  deliverNotBefore DateTime?
  originId         String
  destinationId    String
  metaContent      String?
  isMetaEncrypted  Boolean
  constraints      Json?
  priorityClass    String
  payment          Float
  senderCityId     String?
  receivedAt       DateTime  @default(now())

  @@index([packageId, receivedAt])
  @@index([destinationId])
}

model Route {
  code          String   @id
  name          String
  enabled       Boolean  @default(false)
  distance      BigInt?
  transportCost BigInt?
  updatedAt     DateTime @updatedAt
}

model AuditEvent {
  idpk      String   @id
  packageId String
  type      String
  data      Json?
  createdAt DateTime @default(now())

  @@index([packageId, createdAt])
  @@index([type])
}

model User {
  id        String   @id @default(uuid())
  subject   String   @unique
  email     String?
  role      String   @default("user")
  createdAt DateTime @default(now())
}

// RF01
model UserShipment {
  id               String    @id @default(uuid())
  ownerSubject     String
  packageId        String    @unique // RF04
  originId         String
  destinationId    String
  height           Int
  width            Int
  depth            Int
  criteria         String
  maxHops          Int
  deliveryStrategy String    @default("random")
  priorityClass    String    @default("medium")
  deliverNotBefore DateTime?
  metaContent      String?
  // RF02/RF03
  routeMetricCost  BigInt
  fPrice           Float
  amount           Int
  hops             Int
  nextHop          String?
  routePath        Json
  status           String    @default("pending-payment")
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([ownerSubject, createdAt])
}

// RF03
model Payment {
  id                String    @id @default(uuid())
  shipmentId        String
  ownerSubject      String
  buyOrder          String    @unique
  webpayToken       String?   @unique
  sessionId         String
  redirectUrl       String?
  amount            Int
  currency          String    @default("CLP")
  status            String    @default("TRYING")
  authorizationCode String?
  reason            String?
  transactionDate   DateTime?
  responseRaw       Json?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([shipmentId])
  @@index([ownerSubject])
}

model Job {
  id        String   @id @default(uuid())
  type      String
  status    String   @default("pending")
  payload   Json?
  result    Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// RF06
model ReceivedTable {
  sourceCityId String   @id
  distances    Json
  receivedAt   DateTime @default(now())
}

// RF02
model CalculatedRoute {
  id              String   @id @default(uuid())
  destinationCode String
  criteria        String
  nextHop         String?
  routeMetricCost BigInt?
  hops            Int?
  path            Json
  reachable       Boolean  @default(false)
  updatedAt       DateTime @updatedAt

  @@unique([destinationCode, criteria])
}
