{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  }
  ,
  "moduleNameMapper": {
    "^@/(.*)$": "<rootDir>/../src/$1",
    "^@packages/(.*)$": "<rootDir>/../src/packages/$1",
    "^@dto/(.*)$": "<rootDir>/../src/dto/$1"
  }
}
